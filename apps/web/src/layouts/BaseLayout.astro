---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
// Vite-resolved font URLs — hashed /_astro/ paths that match the @font-face
// declarations bundled from @fontsource. Hardcoded /@fontsource-… paths 404
// in the built site, so preloads must go through the bundler.
import interLatinUrl from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';
import interVietnameseUrl from '@fontsource-variable/inter/files/inter-vietnamese-wght-normal.woff2?url';

interface Props {
  lang: 'en' | 'vi';
  title: string;
  description?: string;
  canonicalUrl?: string;
  /** URL of the sibling page in the opposite locale (for hreflang) */
  alternateUrl?: string;
  ogImage?: string;
  /** OpenGraph type — lesson pages pass "article"; everything else is a website page */
  ogType?: 'website' | 'article';
}

const {
  lang,
  title,
  description = 'RF · Core Network · Space — Bilingual Open Learning Platform',
  canonicalUrl = Astro.url.href,
  alternateUrl,
  ogImage,
  ogType = 'website',
} = Astro.props;

const oppositeLang = lang === 'en' ? 'vi' : 'en';
const siteName = 'RFCN Space Handbook';
---

<!doctype html>
<html lang={lang} dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title} | {siteName}</title>
    <meta name="description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- hreflang alternates for bilingual SEO -->
    <link rel="alternate" hreflang={lang} href={canonicalUrl} />
    {alternateUrl && (
      <link rel="alternate" hreflang={oppositeLang} href={alternateUrl} />
    )}
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />

    <!-- OpenGraph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={`${title} | ${siteName}`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={lang === 'vi' ? 'vi_VN' : 'en_US'} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Favicon placeholder — Phase 8 provides real assets -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Font preloads — Inter variable (all text: body, headings, display).
         Preload latin (primary script) + vietnamese (bilingual VI diacritics).
         crossorigin required: fonts are fetched with CORS. -->
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href={interLatinUrl}
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href={interVietnameseUrl}
      crossorigin="anonymous"
    />

    <!--
      Dark-mode bootstrap script — runs before first paint to prevent FOUC.
      Priority order: localStorage > OS prefers-color-scheme > default (light).
      Sets .theme-dark or .theme-light on <html> so tokens.css overrides apply
      before any CSS is painted. External file is CSP script-src 'self' compliant.
    -->
    <script is:inline src="/dark-mode-init.js"></script>
  </head>
  <body>
    <Header lang={lang} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
