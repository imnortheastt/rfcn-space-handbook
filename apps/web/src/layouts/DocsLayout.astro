---
/**
 * DocsLayout — documentation-style layout with sidebar navigation.
 * Used for domain index pages and lesson pages.
 * Homepage uses BaseLayout (no sidebar).
 *
 * Tablet (769–1024px): sidebar-toggle button collapses/expands DocsSidebar off-canvas.
 * Collapsed state persists to localStorage under key "sidebar-collapsed".
 */
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import DocsSidebar from '../components/DocsSidebar.astro';
import CodeBlockChrome from '../components/CodeBlockChrome.astro';
import BackToTop from '../components/BackToTop.astro';
// Vite-resolved font URLs — hashed /_astro/ paths that match the @font-face
// declarations bundled from @fontsource. Hardcoded /@fontsource-… paths 404
// in the built site, so preloads must go through the bundler.
import interLatinUrl from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';
import interVietnameseUrl from '@fontsource-variable/inter/files/inter-vietnamese-wght-normal.woff2?url';

interface Props {
  lang: 'en' | 'vi';
  domain: 'rf' | 'core-network' | 'space';
  title: string;
  description?: string;
  canonicalUrl?: string;
  alternateUrl?: string;
  ogImage?: string;
  currentPath?: string;
  /** OpenGraph type — lesson pages pass "article"; index pages are website pages */
  ogType?: 'website' | 'article';
}

const {
  lang,
  domain,
  title,
  description = 'RF · Core Network · Space — Bilingual Open Learning Platform',
  canonicalUrl = Astro.url.href,
  alternateUrl,
  ogImage,
  currentPath = Astro.url.pathname,
  ogType = 'website',
} = Astro.props;

const oppositeLang = lang === 'en' ? 'vi' : 'en';
const siteName = 'RFCN Space Handbook';
---

<!doctype html>
<html lang={lang} dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title} | {siteName}</title>
    <meta name="description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- hreflang alternates for bilingual SEO -->
    <link rel="alternate" hreflang={lang} href={canonicalUrl} />
    {alternateUrl && (
      <link rel="alternate" hreflang={oppositeLang} href={alternateUrl} />
    )}
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />

    <!-- OpenGraph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={`${title} | ${siteName}`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={lang === 'vi' ? 'vi_VN' : 'en_US'} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Font preloads — Inter variable (all text: body, headings, display).
         Preload latin (primary script) + vietnamese (bilingual VI diacritics).
         crossorigin required: fonts are fetched with CORS. -->
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href={interLatinUrl}
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href={interVietnameseUrl}
      crossorigin="anonymous"
    />

    <!-- Dark-mode bootstrap script -->
    <script is:inline src="/dark-mode-init.js"></script>
  </head>
  <body>
    <Header lang={lang} />

    <!--
      Tablet sidebar toggle — visible only at 769–1024px via CSS.
      Positioned in the content flow so it sits above the docs-container.
    -->
    <div class="sidebar-toggle-bar">
      <button
        class="sidebar-toggle-btn"
        id="sidebar-toggle-btn"
        type="button"
        aria-label="Toggle sidebar navigation"
        aria-expanded="true"
        aria-controls="docs-sidebar"
      >
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <rect x="1" y="3" width="16" height="2" rx="1" fill="currentColor"/>
          <rect x="1" y="8" width="10" height="2" rx="1" fill="currentColor"/>
          <rect x="1" y="13" width="16" height="2" rx="1" fill="currentColor"/>
        </svg>
        <span class="sidebar-toggle-label">Menu</span>
      </button>
    </div>

    <!-- Mobile sidebar backdrop — click closes drawer, hidden on tablet/desktop -->
    <div class="sidebar-backdrop" id="sidebar-backdrop" aria-hidden="true" hidden></div>

    <div class="docs-container" id="docs-container">
      <DocsSidebar lang={lang} domain={domain} currentPath={currentPath} />
      <main id="main" class="docs-content">
        <slot />
      </main>
      <div class="docs-toc-col">
        <slot name="toc" />
      </div>
    </div>
    <Footer lang={lang} />
    <CodeBlockChrome />
    <BackToTop />
  </body>
</html>

<script>
  /**
   * Sidebar toggle — wires toggle button to DocsSidebar's is-collapsed class.
   * Covers mobile (≤768px) and tablet (769–1024px).
   * On mobile, also manages backdrop, Esc close, and focus trap (mirrors HamburgerMenu pattern).
   * Persists state to localStorage under "sidebar-collapsed".
   */

  const FOCUSABLE_SELECTORS =
    'a[href], button:not([disabled]), input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])';

  function initSidebarToggle() {
    const toggleBtn = document.getElementById('sidebar-toggle-btn') as HTMLButtonElement | null;
    const sidebar = document.getElementById('docs-sidebar') as HTMLElement | null;
    const backdrop = document.getElementById('sidebar-backdrop') as HTMLElement | null;

    if (!toggleBtn || !sidebar) return;

    const isMobile = () => window.matchMedia('(max-width: 768px)').matches;

    // Apply persisted state — on mobile default to collapsed
    const storedCollapsed = localStorage.getItem('sidebar-collapsed');
    const startCollapsed = isMobile()
      ? storedCollapsed !== 'false'   // mobile: collapsed unless explicitly opened
      : storedCollapsed === 'true';   // tablet: respect stored value
    if (startCollapsed) {
      sidebar.classList.add('is-collapsed');
      toggleBtn.setAttribute('aria-expanded', 'false');
    } else {
      toggleBtn.setAttribute('aria-expanded', 'true');
    }

    function trapFocus(e: KeyboardEvent) {
      if (e.key !== 'Tab') return;
      const focusable = Array.from(
        sidebar!.querySelectorAll<HTMLElement>(FOCUSABLE_SELECTORS)
      ).filter((el) => el.offsetParent !== null);
      if (focusable.length === 0) { e.preventDefault(); return; }
      const first = focusable[0] as HTMLElement;
      const last = focusable[focusable.length - 1] as HTMLElement;
      if (e.shiftKey) {
        if (document.activeElement === first) { e.preventDefault(); last.focus(); }
      } else {
        if (document.activeElement === last) { e.preventDefault(); first.focus(); }
      }
    }

    function openSidebar() {
      sidebar!.classList.remove('is-collapsed');
      toggleBtn!.setAttribute('aria-expanded', 'true');
      localStorage.setItem('sidebar-collapsed', 'false');
      if (isMobile() && backdrop) {
        backdrop.hidden = false;
        document.body.style.overflow = 'hidden';
        sidebar!.addEventListener('keydown', trapFocus);
        // Esc closes on mobile
        document.addEventListener('keydown', handleEsc);
      }
    }

    function closeSidebar() {
      sidebar!.classList.add('is-collapsed');
      toggleBtn!.setAttribute('aria-expanded', 'false');
      localStorage.setItem('sidebar-collapsed', 'true');
      if (backdrop) {
        backdrop.hidden = true;
      }
      document.body.style.overflow = '';
      sidebar!.removeEventListener('keydown', trapFocus);
      document.removeEventListener('keydown', handleEsc);
      toggleBtn?.focus();
    }

    function handleEsc(e: KeyboardEvent) {
      if (e.key === 'Escape') closeSidebar();
    }

    toggleBtn.addEventListener('click', () => {
      const isCollapsed = sidebar!.classList.contains('is-collapsed');
      isCollapsed ? openSidebar() : closeSidebar();
    });

    backdrop?.addEventListener('click', closeSidebar);

    // Close mobile drawer when viewport widens past 768px
    window.matchMedia('(min-width: 769px)').addEventListener('change', (e) => {
      if (e.matches && backdrop && !backdrop.hidden) {
        closeSidebar();
      }
    });
  }

  initSidebarToggle();
  document.addEventListener('astro:after-swap', initSidebarToggle);
</script>

<style is:global>
  .docs-container {
    display: grid;
    grid-template-columns: 240px minmax(0, 1fr) 200px;
    gap: 0;
    min-height: calc(100vh - 4rem);
  }

  .docs-content {
    min-width: 0;
    padding: var(--space-6);
    max-width: var(--measure);
    /* center prose within the track */
    margin-inline: auto;
  }

  /* Right ToC column — passes through its slot content */
  .docs-toc-col {
    min-width: 0;
    border-left: 1px solid var(--color-border);
  }

  @media (max-width: 1024px) {
    .docs-container {
      grid-template-columns: 240px minmax(0, 1fr);
    }

    .docs-toc-col {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .docs-container {
      grid-template-columns: 1fr;
    }
  }

  /* Sidebar toggle bar — visible on mobile + tablet (≤1024px); hidden on desktop */
  .sidebar-toggle-bar {
    display: none;
  }

  @media (max-width: 1024px) {
    .sidebar-toggle-bar {
      display: flex;
      align-items: center;
      padding: var(--space-2) var(--space-4);
      border-bottom: 1px solid var(--color-border);
      background: var(--color-surface);
    }
  }

  .sidebar-toggle-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-1) var(--space-3);
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    color: var(--color-fg);
    font-size: var(--font-size-sm);
    cursor: pointer;
    transition: background-color 0.15s ease;
  }

  @media (prefers-reduced-motion: reduce) {
    .sidebar-toggle-btn {
      transition: none;
    }
  }

  .sidebar-toggle-btn:hover {
    background-color: var(--color-surface-elevated);
  }

  .sidebar-toggle-btn:focus-visible {
    outline: var(--focus-ring);
    outline-offset: 2px;
  }

  /* Mobile backdrop — dim overlay behind off-canvas sidebar */
  .sidebar-backdrop {
    position: fixed;
    inset: 0;
    z-index: 199;
    background-color: rgba(0, 0, 0, 0.35);
  }

  @media (max-width: 768px) {
    .docs-content {
      padding: var(--space-4);
    }
  }
</style>
