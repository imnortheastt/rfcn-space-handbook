---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchBox from '../components/SearchBox.astro';

// Search is locale-agnostic at the URL level; detect from query param or default to en
const langParam = Astro.url.searchParams.get('lang');
const lang = langParam === 'vi' ? 'vi' : 'en';
---

<BaseLayout lang={lang} title={lang === 'en' ? 'Search' : 'Tìm kiếm'}>
  <main>
    <h1>{lang === 'en' ? 'Search lessons' : 'Tìm kiếm bài học'}</h1>

    <!-- Language filter links -->
    <nav aria-label="Search language filter" class="search-lang-filter">
      <a href="/search?lang=en" aria-current={lang === 'en' ? 'page' : undefined}>English</a>
      <a href="/search?lang=vi" aria-current={lang === 'vi' ? 'page' : undefined}>Tiếng Việt</a>
    </nav>

    <SearchBox lang={lang} />
  </main>
</BaseLayout>
