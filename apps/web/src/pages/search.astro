---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchBox from '../components/SearchBox.astro';

// Search is locale-agnostic at the URL level; detect from query param or default to en
const langParam = Astro.url.searchParams.get('lang');
const lang = langParam === 'vi' ? 'vi' : 'en';
---

<BaseLayout lang={lang} title={lang === 'en' ? 'Search' : 'Tìm kiếm'}>
  <div class="search-page">
    <header class="search-page__header">
      <h1 class="search-page__title">{lang === 'en' ? 'Search lessons' : 'Tìm kiếm bài học'}</h1>
      <p class="search-page__sub">
        {lang === 'en' ? 'Full-text search across all bilingual lessons.' : 'Tìm kiếm toàn văn trong tất cả bài học song ngữ.'}
      </p>
    </header>

    <!-- Language filter links -->
    <nav aria-label="Search language filter" class="search-lang-filter">
      <a href="/search?lang=en" class="search-lang-filter__link" aria-current={lang === 'en' ? 'page' : undefined}>English</a>
      <a href="/search?lang=vi" class="search-lang-filter__link" aria-current={lang === 'vi' ? 'page' : undefined}>Tiếng Việt</a>
    </nav>

    <SearchBox lang={lang} />
  </div>
</BaseLayout>

<style>
  .search-page {
    max-width: 640px;
    margin: 0 auto;
    padding: var(--space-12) var(--space-4) var(--space-16);
    color: var(--color-fg);
  }

  .search-page__header {
    margin-bottom: var(--space-8);
  }

  .search-page__title {
    font-size: var(--font-size-3xl);
    font-weight: 700;
    color: var(--color-fg);
    margin: 0 0 var(--space-2);
    letter-spacing: -0.02em;
  }

  .search-page__sub {
    font-size: var(--font-size-base);
    color: var(--color-muted);
    margin: 0;
  }

  .search-lang-filter {
    display: flex;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
  }

  .search-lang-filter__link {
    padding: var(--space-1) var(--space-3);
    font-size: var(--font-size-sm);
    color: var(--color-muted);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    text-decoration: none;
    transition: color 0.1s, border-color 0.1s, background 0.1s;
  }

  .search-lang-filter__link:hover {
    color: var(--color-accent-link);
    border-color: var(--color-accent-link);
    background: var(--color-surface-elevated);
  }

  .search-lang-filter__link[aria-current="page"] {
    color: var(--color-accent-link);
    border-color: var(--color-accent-link);
    background: var(--color-accent-50);
    font-weight: 600;
  }

  .search-lang-filter__link:focus-visible {
    box-shadow: var(--focus-ring);
    outline: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .search-lang-filter__link {
      transition: none;
    }
  }
</style>
