---
// Astro redirects config handles the server-side redirect (/ → /en/).
// This meta-refresh is a belt-and-suspenders fallback for static hosts
// that don't process the redirects config.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content="0; url=/en/" />
    <title>Redirecting…</title>
  </head>
  <body>
    <p>Redirecting to <a href="/en/">/en/</a>…</p>
  </body>
</html>
