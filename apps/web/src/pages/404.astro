---
/**
 * 404 — static not-found page.
 * Astro outputs dist/404.html; Vercel/Netlify serve it automatically.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout lang="en" title="Page not found">
  <div class="not-found">
    <p class="not-found__code" aria-hidden="true">404</p>
    <h1 class="not-found__heading">Page not found</h1>
    <p class="not-found__sub">Trang không tồn tại</p>

    <nav class="not-found__links" aria-label="Recovery navigation">
      <a href="/en/" class="not-found__btn hover-lift">English home</a>
      <a href="/vi/" class="not-found__btn hover-lift">Trang chủ tiếng Việt</a>
      <a href="/search" class="not-found__btn hover-lift">Search</a>
    </nav>
  </div>
</BaseLayout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--space-16) var(--space-4);
    min-height: 60vh;
    gap: var(--space-4);
  }

  .not-found__code {
    font-family: var(--font-mono);
    font-size: clamp(5rem, 20vw, 10rem);
    font-weight: 700;
    color: var(--color-surface-elevated);
    line-height: 1;
    margin: 0;
    letter-spacing: -0.04em;
    user-select: none;
  }

  .not-found__heading {
    font-size: var(--font-size-2xl);
    font-weight: 700;
    color: var(--color-fg);
    margin: 0;
  }

  .not-found__sub {
    font-size: var(--font-size-base);
    color: var(--color-muted);
    margin: 0;
  }

  .not-found__links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-3);
    margin-top: var(--space-8);
  }

  /* Ghost button — border only, hover-lift adds border-color + elevation */
  .not-found__btn {
    display: inline-flex;
    align-items: center;
    padding: var(--space-2) var(--space-5);
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    text-decoration: none;
    color: var(--color-fg);
    font-size: var(--font-size-sm);
    font-weight: 500;
  }

  .not-found__btn:focus-visible {
    box-shadow: var(--focus-ring);
    outline: none;
  }
</style>
