---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SUPPORTED_LOCALES, t } from '../../lib/i18n';
import type { Locale } from '../../lib/i18n';

export function getStaticPaths() {
  return SUPPORTED_LOCALES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const oppositeLang = lang === 'en' ? 'vi' : 'en';
const alternateUrl = new URL(`/${oppositeLang}/`, Astro.site ?? Astro.url.origin).href;
---

<BaseLayout
  lang={lang}
  title={lang === 'en' ? 'RF · Core Network · Space Handbook' : 'Sổ tay RF · Mạng lõi · Vũ trụ'}
  alternateUrl={alternateUrl}
>
  <main>
    <h1>
      {lang === 'en'
        ? 'RF · Core Network · Space — Open Learning Platform'
        : 'RF · Mạng lõi · Vũ trụ — Nền tảng học tập mở'}
    </h1>
    <p>
      {lang === 'en'
        ? 'A bilingual Vietnamese & English technical handbook for RF engineering, core network architecture, and space engineering.'
        : 'Sổ tay kỹ thuật song ngữ Việt–Anh về kỹ thuật RF, kiến trúc mạng lõi và kỹ thuật vũ trụ.'}
    </p>
    <nav aria-label="Domains">
      <ul>
        <li><a href={`/${lang}/rf/`}>RF Engineering</a></li>
        <li><a href={`/${lang}/core-network/`}>Core Network</a></li>
        <li><a href={`/${lang}/space/`}>Space Engineering</a></li>
      </ul>
    </nav>
    <a href={`/${lang}/search`}>{t(lang, 'searchPlaceholder')}</a>
  </main>
</BaseLayout>
