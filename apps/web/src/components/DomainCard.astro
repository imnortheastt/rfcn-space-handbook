---
interface Props {
  title: string;
  description: string;
  href: string;
  domain: 'rf' | 'core-network' | 'space';
  count?: number;
  countLabel?: string;
}

const { title, description, href, domain, count, countLabel } = Astro.props;
---

<a href={href} class="domain-card hover-lift">
  <div class="domain-card-header">
    {domain === 'rf' && (
      <svg class="domain-card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="22" height="22">
        <!-- Antenna: vertical mast + two signal arcs -->
        <line x1="12" y1="20" x2="12" y2="10" />
        <line x1="9" y1="20" x2="15" y2="20" />
        <path d="M8.5 13.5 A5 5 0 0 1 15.5 13.5" />
        <path d="M5.5 11 A9 9 0 0 1 18.5 11" />
      </svg>
    )}
    {domain === 'core-network' && (
      <svg class="domain-card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="22" height="22">
        <!-- Network nodes: center hub + 3 satellite nodes with connecting lines -->
        <circle cx="12" cy="12" r="2" />
        <circle cx="5" cy="7" r="1.5" />
        <circle cx="19" cy="7" r="1.5" />
        <circle cx="12" cy="20" r="1.5" />
        <line x1="10.3" y1="10.7" x2="6.3" y2="8.3" />
        <line x1="13.7" y1="10.7" x2="17.7" y2="8.3" />
        <line x1="12" y1="14" x2="12" y2="18.5" />
      </svg>
    )}
    {domain === 'space' && (
      <svg class="domain-card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="22" height="22">
        <!-- Satellite: body rect + two solar panels + signal line -->
        <rect x="9" y="9" width="6" height="6" rx="1" />
        <line x1="3" y1="12" x2="9" y2="12" />
        <line x1="15" y1="12" x2="21" y2="12" />
        <line x1="3" y1="10" x2="3" y2="14" />
        <line x1="21" y1="10" x2="21" y2="14" />
        <line x1="12" y1="15" x2="16" y2="20" />
      </svg>
    )}
  </div>

  <h3 class="domain-card-title">{title}</h3>
  <p class="domain-card-desc">{description}</p>

  <div class="domain-card-footer">
    {count !== undefined && countLabel && (
      <span class="domain-card-count">{count} {countLabel}</span>
    )}
    <span class="domain-card-arrow" aria-hidden="true">→</span>
  </div>
</a>

<style>
  .domain-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-6);
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    text-decoration: none;
    transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
    cursor: pointer;
  }

  .domain-card:hover {
    border-color: var(--color-accent-link);
    text-decoration: none;
  }

  .domain-card:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring);
    border-color: var(--color-accent-link);
  }

  .domain-card:active {
    border-color: var(--color-accent-strong);
  }

  /* Icon: muted by default, teal on hover */
  .domain-card-header {
    margin-bottom: var(--space-4);
  }

  .domain-card-icon {
    color: var(--color-muted);
    display: block;
    transition: color 0.15s ease, transform 0.15s ease;
  }

  .domain-card:hover .domain-card-icon,
  .domain-card:focus-visible .domain-card-icon {
    color: var(--color-accent-link);
    transform: scale(1.05);
  }

  @media (prefers-reduced-motion: reduce) {
    .domain-card-icon {
      transition: color 0.15s ease;
    }

    .domain-card:hover .domain-card-icon,
    .domain-card:focus-visible .domain-card-icon {
      transform: none;
    }
  }

  .domain-card-title {
    font-size: 1.1875rem;
    font-weight: 600;
    color: var(--color-fg);
    margin: 0 0 var(--space-2) 0;
    line-height: var(--leading-tight);
    transition: color 0.15s ease;
  }

  .domain-card:hover .domain-card-title,
  .domain-card:focus-visible .domain-card-title {
    color: var(--color-accent-link);
  }

  .domain-card-desc {
    font-size: 0.9375rem;
    color: var(--color-muted);
    line-height: 1.5;
    margin: 0;
    flex: 1;
  }

  .domain-card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: var(--space-4);
  }

  .domain-card-count {
    font-size: var(--font-size-sm);
    color: var(--color-muted);
  }

  /* Arrow: muted → teal + shift on hover */
  .domain-card-arrow {
    font-size: var(--font-size-base);
    color: var(--color-muted);
    transition: color 0.15s ease, transform 0.15s ease;
    margin-left: auto;
    display: inline-block;
  }

  .domain-card:hover .domain-card-arrow,
  .domain-card:focus-visible .domain-card-arrow {
    color: var(--color-accent-link);
    transform: translateX(3px);
  }

  @media (prefers-reduced-motion: reduce) {
    .domain-card-arrow {
      transition: color 0.15s ease;
    }

    .domain-card:hover .domain-card-arrow,
    .domain-card:focus-visible .domain-card-arrow {
      transform: none;
    }
  }
</style>
