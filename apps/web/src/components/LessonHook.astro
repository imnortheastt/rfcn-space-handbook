---
/**
 * LessonHook — the opening "hook" section of a lesson.
 * Captures reader attention before diving into content.
 * Blueprint §4.2: first section in every lesson template.
 * No chapter-header/index — styled as lead paragraph via .lesson-hook in base.css.
 */
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<section class:list={['lesson-hook', className]} aria-label="Lesson hook">
  <slot />
</section>
