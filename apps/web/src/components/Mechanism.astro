---
/**
 * Mechanism — the formal derivation / mechanics section.
 * Blueprint §4.2: introduces math, equations, and precise definitions
 * after intuition has been established.
 * Renders as a numbered chapter with .chapter-index counter span.
 */
interface Props {
  class?: string;
  lang?: 'en' | 'vi';
}
const { class: className, lang = 'en' } = Astro.props;
const title = lang === 'vi' ? 'Cơ chế' : 'Mechanism';
const headingId = 'section-mechanism';
---

<section class:list={['lesson-mechanism', className]} aria-labelledby={headingId}>
  <header class="chapter-header">
    <span class="chapter-index" aria-hidden="true"></span>
    <h2 id={headingId}>{title}</h2>
  </header>
  <slot />
</section>
