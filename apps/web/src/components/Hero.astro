---
import type { Locale } from '../lib/i18n';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

const content = {
  en: {
    tagline: 'Master RF, Core Network, and Space Systems',
    subtitle: 'A bilingual technical handbook for engineers — Vietnamese & English',
    ctaPrimary: 'Start learning →',
    ctaSecondary: 'Browse the roadmap',
    ctaPrimaryHref: '/en/rf/',
    ctaSecondaryHref: '/en/rf/',
  },
  vi: {
    tagline: 'Làm chủ RF, Core Network và Hệ thống Không gian',
    subtitle: 'Sổ tay kỹ thuật song ngữ Việt–Anh cho kỹ sư viễn thông',
    ctaPrimary: 'Bắt đầu học →',
    ctaSecondary: 'Xem lộ trình',
    ctaPrimaryHref: '/vi/rf/',
    ctaSecondaryHref: '/vi/rf/',
  },
} as const;

const { tagline, subtitle, ctaPrimary, ctaSecondary, ctaPrimaryHref, ctaSecondaryHref } = content[lang];
---

<section class="hero">
  <h1 class="hero-title">{tagline}</h1>
  <p class="hero-subtitle">{subtitle}</p>
  <div class="hero-actions">
    <a href={ctaPrimaryHref} class="hero-btn hero-btn-primary hover-lift">{ctaPrimary}</a>
    <a href={ctaSecondaryHref} class="hero-btn hero-btn-ghost hover-lift">{ctaSecondary}</a>
  </div>
</section>

<style>
  .hero {
    text-align: center;
    padding-block: var(--space-16);
    padding-inline: var(--space-4);
    max-width: var(--measure);
    margin-inline: auto;
    background: radial-gradient(60% 50% at 50% 0%, var(--color-accent-50) 0%, transparent 70%);
  }

  /* Dark mode: accent-50 is very light — swap to a deep accent wash */
  :global(.theme-dark) .hero {
    background: radial-gradient(60% 50% at 50% 0%, color-mix(in srgb, var(--color-accent-900) 35%, transparent) 0%, transparent 70%);
  }

  @media (prefers-color-scheme: dark) {
    :global(:root:not(.theme-light)) .hero {
      background: radial-gradient(60% 50% at 50% 0%, color-mix(in srgb, var(--color-accent-900) 35%, transparent) 0%, transparent 70%);
    }
  }

  .hero-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    line-height: 1.2;
    color: var(--color-fg);
    margin-bottom: var(--space-4);
    margin-top: 0;
  }

  .hero-subtitle {
    font-size: var(--font-size-lg);
    color: var(--color-muted);
    margin-bottom: var(--space-8);
    max-width: 60ch;
    margin-inline: auto;
    line-height: var(--leading-base);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero-btn {
    display: inline-block;
    padding: var(--space-3) var(--space-8);
    border-radius: 6px;
    font-size: var(--font-size-base);
    font-weight: 600;
    text-decoration: none;
    transition: background-color 0.15s ease, border-color 0.15s ease, color 0.15s ease;
    cursor: pointer;
  }

  /* Primary CTA: filled teal, no shadow/glow */
  .hero-btn-primary {
    background-color: var(--color-accent-link);
    color: var(--color-bg);
    border: 1px solid transparent;
  }

  .hero-btn-primary:hover {
    background-color: var(--color-accent-strong);
    color: var(--color-bg);
    text-decoration: none;
  }

  /* Secondary CTA: ghost */
  .hero-btn-ghost {
    background-color: transparent;
    color: var(--color-fg);
    border: 1px solid var(--color-border);
  }

  .hero-btn-ghost:hover {
    border-color: var(--color-accent-link);
    color: var(--color-fg);
    text-decoration: none;
  }

  /* Focus rings */
  .hero-btn:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring);
  }

  /* Active: subtle press */
  .hero-btn:active {
    transform: translateY(1px);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-btn:active {
      transform: none;
    }
  }
</style>
