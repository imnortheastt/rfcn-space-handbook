---
/**
 * BackToTop — fixed bottom-right button, visible after 600px scroll.
 * Re-initialises on astro:after-swap (idempotent via flag).
 */
---

<button
  id="back-to-top"
  class="back-to-top"
  type="button"
  aria-label="Back to top"
  hidden
>
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <polyline points="18 15 12 9 6 15"/>
  </svg>
</button>

<script>
  function initBackToTop() {
    const btn = document.getElementById('back-to-top') as HTMLButtonElement | null;
    if (!btn) return;

    // Remove any previous listener by replacing with clone
    const fresh = btn.cloneNode(true) as HTMLButtonElement;
    btn.parentNode!.replaceChild(fresh, btn);

    let ticking = false;

    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        fresh.hidden = window.scrollY <= 600;
        ticking = false;
      });
    }

    fresh.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    window.addEventListener('scroll', onScroll, { passive: true });
    // Set initial state
    fresh.hidden = window.scrollY <= 600;
  }

  initBackToTop();
  document.addEventListener('astro:after-swap', initBackToTop);
</script>

<style>
  .back-to-top {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 100;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 50%;
    color: var(--color-fg);
    cursor: pointer;
    transition: box-shadow 0.15s ease, transform 0.15s ease;
  }

  .back-to-top:hover {
    box-shadow: var(--shadow-hover);
    transform: translateY(-2px);
  }

  .back-to-top:focus-visible {
    box-shadow: var(--focus-ring);
    outline: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .back-to-top {
      transition: none;
    }

    .back-to-top:hover {
      transform: none;
    }
  }

  @media print {
    .back-to-top {
      display: none;
    }
  }
</style>
