---
interface Props {
  level: string;
}
const { level } = Astro.props;
---

<span class="level-badge" data-level={level}>{level}</span>

<style>
  .level-badge {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 2px 6px;
    border-radius: 4px;
    white-space: nowrap;
    display: inline-block;
  }

  /* L0/L1 → tier-0 */
  .level-badge[data-level="L0"],
  .level-badge[data-level="L1"] {
    background: var(--color-lesson-tier-0);
    color: var(--color-lesson-text-0);
  }

  /* L2/L3 → tier-1 */
  .level-badge[data-level="L2"],
  .level-badge[data-level="L3"] {
    background: var(--color-lesson-tier-1);
    color: var(--color-lesson-text-1);
  }

  /* L4/L5 → tier-2 */
  .level-badge[data-level="L4"],
  .level-badge[data-level="L5"] {
    background: var(--color-lesson-tier-2);
    color: var(--color-lesson-text-2);
  }
</style>
