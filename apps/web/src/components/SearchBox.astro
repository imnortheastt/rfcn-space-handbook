---
/**
 * SearchBox — Pagefind UI mount point (FR-04).
 * Pagefind scripts are available at /pagefind/ after `astro build && pagefind --site dist`.
 * In dev mode the /pagefind/ assets don't exist yet; the component renders a
 * disabled search box gracefully.
 */
import { t } from '../lib/i18n';

interface Props {
  lang: 'en' | 'vi';
}

const { lang } = Astro.props;
---

<div class="search-box" data-lang={lang}>
  <div id="pagefind-search"></div>
</div>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
<script src="/pagefind/pagefind-ui.js" is:inline></script>
<script define:vars={{ lang, placeholder: t(lang, 'searchPlaceholder') }}>
  // Pagefind UI is only available after `astro build && pagefind --site dist`.
  // In dev, PagefindUI is undefined; skip gracefully.
  if (typeof window !== 'undefined' && typeof window.PagefindUI !== 'undefined') {
    new window.PagefindUI({
      element: '#pagefind-search',
      showImages: false,
      translations: {
        placeholder: placeholder,
      },
    });
  }
</script>

<style>
  /* Search box wrapper — full width up to page container */
  .search-box {
    width: 100%;
  }

  /* Map Pagefind UI custom props to design tokens (no raw colors) */
  .search-box :global(#pagefind-search) {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: var(--color-accent-link);
    --pagefind-ui-text: var(--color-fg);
    --pagefind-ui-background: var(--color-bg);
    --pagefind-ui-border: var(--color-border);
    --pagefind-ui-border-radius: 7px;
    --pagefind-ui-tag: var(--color-surface-elevated);
  }

  /* Input field */
  .search-box :global(.pagefind-ui__search-input) {
    border-radius: 7px;
    border-color: var(--color-border);
    background: var(--color-surface);
    color: var(--color-fg);
  }

  /* Focus ring on search input */
  .search-box :global(.pagefind-ui__search-input:focus-visible) {
    box-shadow: var(--focus-ring);
    outline: none;
  }

  /* Result item hover */
  .search-box :global(.pagefind-ui__result:hover) {
    background: var(--color-surface);
  }

  /* Result link */
  .search-box :global(.pagefind-ui__result-link) {
    color: var(--color-accent-link);
  }
</style>
