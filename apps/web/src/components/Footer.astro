---
import type { Locale } from '../lib/i18n';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
---

<footer class="site-footer">
  <div class="footer-inner">
    <!-- Row 1: nav links (left) + GitHub link (right) -->
    <div class="footer-row footer-row-primary">
      <nav class="footer-nav" aria-label="Footer navigation">
        <a href={`/${lang}/rf/`}>{lang === 'en' ? 'RF' : 'RF'}</a>
        <a href={`/${lang}/core-network/`}>{lang === 'en' ? 'Core Network' : 'Mạng lõi'}</a>
        <a href={`/${lang}/space/`}>{lang === 'en' ? 'Space' : 'Vũ trụ'}</a>
        <a href={`/${lang}/glossary/`}>{lang === 'en' ? 'Glossary' : 'Từ điển'}</a>
      </nav>
      <a
        href="https://github.com/rfcn-space/handbook"
        class="footer-github"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="View source on GitHub"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.167 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.603-3.369-1.342-3.369-1.342-.454-1.154-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.741 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
        </svg>
        GitHub
      </a>
    </div>

    <!-- Row 2: copyright + license, separated by hairline -->
    <div class="footer-row footer-row-secondary">
      <p class="footer-copyright">&copy; {new Date().getFullYear()} RFCN Space Handbook</p>
      <span class="footer-license">MIT License</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-10);
    padding-inline: var(--space-4);
    margin-top: var(--space-16);
  }

  .footer-inner {
    max-width: var(--measure-wide);
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Row 1 */
  .footer-row-primary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-4);
    padding-bottom: var(--space-4);
  }

  /* Row 2: hairline separator + secondary info */
  .footer-row-secondary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-3);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
    font-size: 0.8125rem;
    color: var(--color-muted);
  }

  .footer-nav {
    display: flex;
    gap: var(--space-6);
    flex-wrap: wrap;
    align-items: center;
  }

  .footer-nav a {
    color: var(--color-muted);
    text-decoration: none;
    font-size: var(--font-size-sm);
    transition: color 0.15s ease;
  }

  .footer-nav a:hover {
    color: var(--color-accent-link);
  }

  .footer-github {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-muted);
    text-decoration: none;
    font-size: var(--font-size-sm);
    transition: color 0.15s ease;
  }

  .footer-github:hover {
    color: var(--color-accent-link);
  }

  .footer-copyright {
    margin: 0;
    font-size: 0.8125rem;
    color: var(--color-muted);
  }

  .footer-license {
    font-size: 0.8125rem;
    color: var(--color-muted);
    opacity: 0.8;
  }
</style>
