---
/**
 * MathBlock — wrapper for display-mode KaTeX equations.
 * Provides accessible figure+figcaption wrapping for WCAG compliance.
 * KaTeX is rendered server-side via rehype-katex in astro.config.mjs.
 */
interface Props {
  label?: string;
  class?: string;
}
const { label, class: className } = Astro.props;
---

<figure class:list={['lesson-math-block', className]} role="math" aria-label={label}>
  <slot />
  {label && <figcaption class="math-label">{label}</figcaption>}
</figure>
