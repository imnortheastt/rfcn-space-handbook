---
/**
 * Pitfalls — common mistakes and misconceptions section.
 * Blueprint §4.2: addresses the top errors engineers make with this concept.
 * Renders as a numbered chapter with .chapter-index counter span.
 * .chapter-index uses vermillion accent (color-qual-2) in base.css.
 */
interface Props {
  class?: string;
  lang?: 'en' | 'vi';
}
const { class: className, lang = 'en' } = Astro.props;
const title = lang === 'vi' ? 'Lỗi thường gặp' : 'Common Pitfalls';
const headingId = 'section-pitfalls';
---

<section class:list={['lesson-pitfalls', className]} aria-labelledby={headingId}>
  <header class="chapter-header">
    <span class="chapter-index" aria-hidden="true"></span>
    <h2 id={headingId}>{title}</h2>
  </header>
  <slot />
</section>
