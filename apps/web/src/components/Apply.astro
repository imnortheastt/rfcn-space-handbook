---
/**
 * Apply — worked examples and practical applications section.
 * Blueprint §4.2: connects theory to real engineering scenarios.
 * Renders as a numbered chapter with .chapter-index counter span.
 */
interface Props {
  class?: string;
  lang?: 'en' | 'vi';
}
const { class: className, lang = 'en' } = Astro.props;
const title = lang === 'vi' ? 'Ứng dụng' : 'Applied Examples';
const headingId = 'section-apply';
---

<section class:list={['lesson-apply', className]} aria-labelledby={headingId}>
  <header class="chapter-header">
    <span class="chapter-index" aria-hidden="true"></span>
    <h2 id={headingId}>{title}</h2>
  </header>
  <slot />
</section>
