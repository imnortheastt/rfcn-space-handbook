---
// roadmap-svg.astro — renders a static inline SVG roadmap from pre-computed layout.
// Zero client JS. CSS-only styling using design tokens from tokens.css.
// Lesson nodes are keyboard-focusable <a> links using href from LayoutNode.
// PITFALL: never use <style>{`...`}</style> template-literal expressions —
//   Astro emits the backtick string as raw text, leaving rects black.
//   Use plain scoped <style> blocks only.
// PITFALL: CSS custom properties do not inherit into SVG <foreignObject> or
//   standalone <svg> files, but they DO work in inline SVG inside an HTML doc
//   when referenced via var() in a scoped <style> block — which is what we do.
import type { RoadmapLayout } from '../lib/roadmap-layout';
import { levelIndex } from '../lib/roadmap-layout';

interface Props {
  layout: RoadmapLayout;
  lang: 'en' | 'vi';
}

const { layout } = Astro.props;
const { width, height, nodes, trackLabels } = layout;

const LABEL_W = 160;
const SVG_PAD_X = 12;

// Truncate text to fit within lesson box (≈12 chars for 80px width at ~6.5px/char)
function truncate(s: string, max = 11): string {
  return s.length > max ? s.slice(0, max - 1) + '…' : s;
}

// Map level index to tier: L0-L1 → 0, L2-L3 → 1, L4-L5 → 2
function levelToTier(level: string): number {
  const lvl = levelIndex(level);
  if (lvl < 2) return 0;
  if (lvl < 4) return 1;
  return 2;
}
---

<div class="roadmap-scroll">
  <svg
    viewBox={`0 0 ${width} ${height}`}
    width={width}
    height={height}
    aria-label="Domain roadmap"
    role="img"
    xmlns="http://www.w3.org/2000/svg"
    class="roadmap-svg"
  >
    {/* Track bands */}
    {trackLabels.map((tl) => (
      <g>
        <rect
          x={SVG_PAD_X}
          y={tl.y}
          width={width - SVG_PAD_X * 2}
          height={tl.height}
          rx={4}
          class={tl.hasUnits ? 'track-band' : 'track-band-shell'}
        />
        {tl.hasUnits ? (
          <text
            x={SVG_PAD_X + 8}
            y={tl.y + tl.height / 2}
            dominant-baseline="middle"
            class="track-label"
          >
            {truncate(tl.title, 20)}
          </text>
        ) : (
          <text
            x={SVG_PAD_X + LABEL_W / 2}
            y={tl.y + tl.height / 2}
            dominant-baseline="middle"
            text-anchor="middle"
            class="shell-label"
          >
            {truncate(tl.title, 28)}
          </text>
        )}
      </g>
    ))}

    {/* Lesson nodes — each wrapped in an <a> for keyboard navigation.
        SVG <a> uses href (SVG 2). tabindex is not needed — SVG <a> is
        natively focusable. aria-label provides accessible name from full title. */}
    {nodes.map((node) => (
      <a
        href={node.href}
        aria-label={node.title}
        class={`lesson-link lesson-link-tier-${levelToTier(node.level)}`}
      >
        <title>{node.title}</title>
        <rect
          x={node.x}
          y={node.y}
          width={node.w}
          height={node.h}
          rx={2}
          class={`lesson-box lesson-box-tier-${levelToTier(node.level)}`}
        />
        <text
          x={node.x + node.w / 2}
          y={node.y + node.h / 2}
          dominant-baseline="middle"
          text-anchor="middle"
          class={`lesson-text lesson-text-tier-${levelToTier(node.level)}`}
        >
          {truncate(node.title, 11)}
        </text>
      </a>
    ))}
  </svg>
</div>

<div class="roadmap-legend">
  <span class="legend-item">
    <span class="legend-dot legend-dot-tier-0"></span>
    L0–L1
  </span>
  <span class="legend-item">
    <span class="legend-dot legend-dot-tier-1"></span>
    L2–L3
  </span>
  <span class="legend-item">
    <span class="legend-dot legend-dot-tier-2"></span>
    L4–L5
  </span>
</div>

<style>
  /* SVG element styling — plain scoped block, no template-literal expressions.
     CSS vars work here because this is inline SVG in an HTML document. */
  .roadmap-svg {
    font-family: var(--font-sans, system-ui, sans-serif);
    background: var(--color-bg, #ffffff);
  }
  .track-band {
    fill: var(--color-surface-elevated, #eef0f0);
    stroke: var(--color-border, #d4d9d9);
    stroke-width: 1;
  }
  .track-band-shell {
    fill: var(--color-surface, #f7f8f8);
    stroke: var(--color-border, #d4d9d9);
    stroke-width: 1;
    stroke-dasharray: 4 3;
  }
  .track-label {
    font-size: 11px;
    font-weight: 600;
    fill: var(--color-fg, #0e1414);
  }
  .lesson-box {
    stroke: var(--color-border, #d4d9d9);
    stroke-width: 1;
    /* transition only when reduced-motion is not requested — see guard below */
    transition: stroke 0.15s, fill 0.15s;
  }
  .lesson-box-published { fill: var(--color-accent-50, #f0fdfa); stroke: var(--color-accent-500, #14b8a6); }
  .shell-label {
    font-size: 11px;
    fill: var(--color-muted, #5b6766);
    font-style: italic;
  }

  /* Tier-based fills — explicit colors, not opacity, for correct contrast */
  .lesson-box-tier-0 { fill: var(--color-lesson-tier-0, #e8ebeb); }
  .lesson-box-tier-1 { fill: var(--color-lesson-tier-1, #d4d9d9); }
  .lesson-box-tier-2 { fill: var(--color-lesson-tier-2, #c0c7c7); }

  /* Lesson text — use retuned --color-lesson-text-* tokens (≥4.5:1 WCAG AA) */
  .lesson-text { font-size: 9px; pointer-events: none; }
  .lesson-text-tier-0 { fill: var(--color-lesson-text-0, #636e6e); }
  .lesson-text-tier-1 { fill: var(--color-lesson-text-1, #576261); }
  .lesson-text-tier-2 { fill: var(--color-lesson-text-2, #4a5555); }
  .lesson-text-published { fill: var(--color-accent-link, #0f766e); }

  /* ── Lesson link hover/focus states ─────────────────────────────── */
  /* SVG <a> does not naturally inherit box-shadow, so we use stroke on the
     child rect for hover feedback, and an SVG outline rect via CSS for focus. */
  .lesson-link:hover .lesson-box {
    stroke: var(--color-accent-link, #2c8a8f);
    stroke-width: 2;
  }
  .lesson-link:hover .lesson-box-tier-0,
  .lesson-link:hover .lesson-box-tier-1,
  .lesson-link:hover .lesson-box-tier-2 {
    fill: var(--color-accent-50, #f0fdfa);
  }

  /* :focus-visible ring on SVG <a> — use outline since box-shadow doesn't
     render on SVG elements in all browsers. outline-offset gives the double-ring feel. */
  .lesson-link:focus-visible {
    outline: 2px solid var(--color-accent-link, #2c8a8f);
    outline-offset: 2px;
    border-radius: 3px;
  }

  /* Also stroke the inner rect on focus for clarity */
  .lesson-link:focus-visible .lesson-box {
    stroke: var(--color-accent-link, #2c8a8f);
    stroke-width: 2;
  }

  /* Active state: darken fill slightly */
  .lesson-link:active .lesson-box {
    stroke: var(--color-accent-strong, #1d6266);
    stroke-width: 2;
  }

  /* Reduced-motion: disable fill/stroke transitions on nodes */
  @media (prefers-reduced-motion: reduce) {
    .lesson-box {
      transition: none;
    }
  }

  /* ── Scroll container ───────────────────────────────────────────── */
  .roadmap-scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    max-width: 100%;
    border: 1px solid var(--color-border, #d4d9d9);
    border-radius: 8px;
    padding: 1rem;
    background: var(--color-bg, #ffffff);
  }
  .roadmap-scroll::-webkit-scrollbar { height: 8px; }
  .roadmap-scroll::-webkit-scrollbar-track {
    background: var(--color-surface, #f7f8f8);
    border-radius: 4px;
  }
  .roadmap-scroll::-webkit-scrollbar-thumb {
    background: var(--color-border, #d4d9d9);
    border-radius: 4px;
  }
  .roadmap-scroll::-webkit-scrollbar-thumb:hover {
    background: var(--color-muted, #5b6766);
  }

  /* ── Legend ─────────────────────────────────────────────────────── */
  .roadmap-legend {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    margin-top: 1rem;
    font-size: 0.75rem;
    color: var(--color-muted, #5b6766);
  }
  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.375rem;
  }
  .legend-dot {
    width: 12px;
    height: 12px;
    border: 1px solid var(--color-border, #d4d9d9);
    border-radius: 2px;
    display: inline-block;
  }
  .legend-dot-tier-0 { background: var(--color-lesson-tier-0, #e8ebeb); }
  .legend-dot-tier-1 { background: var(--color-lesson-tier-1, #d4d9d9); }
  .legend-dot-tier-2 { background: var(--color-lesson-tier-2, #c0c7c7); }
</style>
