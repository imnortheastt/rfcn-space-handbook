---
/**
 * NavLink — navigation anchor with active state detection.
 * Active when the current pathname starts with the given href,
 * enabling correct highlighting for nested routes (e.g. /en/rf/foo matches /en/rf/).
 */
interface Props {
  href: string;
  label: string;
}

const { href, label } = Astro.props;
const pathname = Astro.url.pathname;
const isActive = pathname.startsWith(href);
---

<a
  href={href}
  class:list={['nav-link', { 'nav-link--active': isActive }]}
  aria-current={isActive ? 'page' : undefined}
>
  {label}
</a>

<style>
  .nav-link {
    display: inline-block;
    padding-block: var(--space-1);
    color: var(--color-muted);
    text-decoration: none;
    font-size: var(--font-size-sm);
    font-weight: 500;
    border-bottom: 2px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .nav-link:hover {
    color: var(--color-fg);
  }

  .nav-link--active {
    color: var(--color-fg);
    font-weight: 600;
    border-bottom-color: var(--color-accent-link);
  }

  .nav-link:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring);
    border-radius: 2px;
  }
</style>
