---
/**
 * Intuition — "understand before you formalize" section.
 * Blueprint §4.2: builds mental model before introducing math.
 * Renders as a numbered chapter with .chapter-index counter span.
 */
interface Props {
  class?: string;
  lang?: 'en' | 'vi';
}
const { class: className, lang = 'en' } = Astro.props;
const title = lang === 'vi' ? 'Trực giác' : 'Intuition';
const headingId = 'section-intuition';
---

<section class:list={['lesson-intuition', className]} aria-labelledby={headingId}>
  <header class="chapter-header">
    <span class="chapter-index" aria-hidden="true"></span>
    <h2 id={headingId}>{title}</h2>
  </header>
  <slot />
</section>
