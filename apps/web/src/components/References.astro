---
/**
 * References — auto-collected bibliography section.
 * Blueprint §4.2 + FR-06: citation rendering at lesson end.
 * Renders as a numbered chapter (last chapter) with .chapter-index counter span.
 */
interface Props {
  class?: string;
  lang?: 'en' | 'vi';
}
const { class: className, lang = 'en' } = Astro.props;
const title = lang === 'vi' ? 'Tài liệu tham khảo' : 'References';
const headingId = 'section-references';
---

<section class:list={['lesson-references', className]} aria-labelledby={headingId}>
  <header class="chapter-header">
    <span class="chapter-index" aria-hidden="true"></span>
    <h2 id={headingId}>{title}</h2>
  </header>
  <slot />
</section>
